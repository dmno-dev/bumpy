{
  "name": "@varlock/bumpy",
  "version": "1.5.0",
  "description": "Modern monorepo versioning and changelog tool",
  "keywords": [
    "bump",
    "changelog",
    "changesets",
    "monorepo",
    "version",
    "version management"
  ],
  "homepage": "https://bumpy.varlock.dev",
  "bugs": "https://github.com/dmno-dev/bumpy/issues",
  "license": "MIT",
  "author": "dmno-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/dmno-dev/bumpy",
    "directory": "packages/bumpy"
  },
  "bin": {
    "bumpy": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "config-schema.json",
    ".claude-plugin",
    "skills"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "cp ../../README.md .",
    "check": "bun run tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/picomatch": "^4.0.3",
    "@types/semver": "^7.7.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "semver": "^7.7.2",
    "tsdown": "catalog:"
  }
}
